      "primary": "#111827",
      "secondary": "#6B7280",
      "inverse": "#FFFFFF"
    }
  },
  "typography": {
    "fontFamily": "'Inter', sans-serif",
    "scale": {
      "display": {
        "fontSize": "32px",
        "fontWeight": "700",
        "lineHeight": "40px"
      },
      "headline": {
        "fontSize": "24px",
        "fontWeight": "600",
        "lineHeight": "32px"
      },
      "body": {
        "fontSize": "16px",
        "fontWeight": "400",
        "lineHeight": "24px"
      },
      "label": {
